# VaultSQL Environment Configuration
# Copy this file to env.txt and fill in the required values.

# =============================================================================
# REQUIRED
# =============================================================================

# Django secret key - generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
API_SECRET_KEY=

# Encryption key for stored credentials - generate same as above
API_ENCRYPTION_KEY=

# Shared secret between API and query service - generate same as above
QUERY_SERVICE_SECRET=

# Database connection
API_DB_HOST=localhost
API_DB_PORT=5432
API_DB_NAME=vaultsql
API_DB_USER=vaultsql
API_DB_PASS=
API_DB_SSLMODE=disable      # use 'require' for managed DBs (RDS, Neon, Supabase)

# =============================================================================
# SERVICE URLS
# =============================================================================

FRONTEND_URL=http://localhost:8400
API_FRONTEND_URL=http://localhost:8400

# =============================================================================
# OPTIONAL TUNING
# =============================================================================

# Set to 'true' to enable Django debug mode (NEVER in production)
API_DEBUG=false

# Environment name shown in logs
API_ENV_NAME=production

# Redis for Celery task queue
API_CELERY_BROKER_URL=redis://redis:6379/0
API_CELERY_RESULT_BACKEND=redis://redis:6379/0

# Query service internal URL
APP_INTERNAL_QUERY=http://query_service:9000

# Comma-separated additional allowed hosts (Caddy handles most routing)
# API_ALLOWED_HOSTS=

# Telemetry/logging (optional). Self-hosted defaults to Docker-managed stdout/stderr logs.
# Leave these unset unless you want remote observability in addition to `docker logs`.
QUERY_SENTRY_DSN=
QUERY_SENTRY_TRACES_SAMPLE_RATE=1.0
QUERY_BETTERSTACK_TOKEN=
QUERY_BETTERSTACK_ENDPOINT=https://in.logs.betterstack.com
