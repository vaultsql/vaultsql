import { Disclosure } from '@headlessui/react'
import {
  ChevronDownIcon,
  CircleStackIcon,
  ClockIcon,
  LockClosedIcon,
  LockOpenIcon,
  MagnifyingGlassIcon,
  PencilIcon,
  ShieldCheckIcon,
} from '@heroicons/react/20/solid'
import { CircleStackIcon as CircleStackIconOutline, FunnelIcon } from '@heroicons/react/24/outline'
import { useMemo, useState } from 'react'
import { Badge } from '@/components/catalyst/badge'
import { Button } from '@/components/catalyst/button'
import { Heading } from '@/components/catalyst/heading'
import { Input, InputGroup } from '@/components/catalyst/input'
import { Select } from '@/components/catalyst/select'
import { Text } from '@/components/catalyst/text'
import { type Access, isAccessActive, isAccessPending, useUserProfiles } from '@/queries/access'
import { type Profile, type Server, useServerProfiles, useServers } from '@/queries/servers'
import { EmptyState, LoadingSpinner } from '@/webapp/components'
import { RequestAccessDialog } from '@/webapp/components/RequestAccessDialog'
import { usePageTitle } from '@/webapp/hooks'
import {
  getAccessLevelBadgeColor,
  getAccessLevelLabel,
  getEnvironmentBadgeColor,
  getEnvironmentLabel,
} from '@/webapp/utils/access-badges'

type AccessFilter = 'all' | 'active' | 'pending' | 'no-access'
type EnvironmentFilter = 'all' | 'production' | 'staging' | 'testing' | 'development' | 'other'

export function HomePage() {
  usePageTitle('Home')
  const { data: accessList = [], isLoading: accessLoading, error: accessError } = useUserProfiles()
  const { data: servers = [], isLoading: serversLoading, error: serversError } = useServers()
  const [searchQuery, setSearchQuery] = useState('')
  const [accessFilter, setAccessFilter] = useState<AccessFilter>('all')
  const [environmentFilter, setEnvironmentFilter] = useState<EnvironmentFilter>('all')

  // Map of profile_id -> access (active access only)
  const accessByProfile = useMemo(() => {
    const map = new Map<string, Access>()
    for (const access of accessList) {
      if (isAccessActive(access) && !map.has(access.profile_id)) {
        map.set(access.profile_id, access)
      }
    }
    return map
  }, [accessList])

  // Map of profile_id -> pending access request
  const pendingByProfile = useMemo(() => {
    const map = new Map<string, Access>()
    for (const access of accessList) {
      if (isAccessPending(access) && !map.has(access.profile_id)) {
        map.set(access.profile_id, access)
      }
    }
    return map
  }, [accessList])

  const normalizedSearch = searchQuery.trim().toLowerCase()
  const accessCounts = useMemo(() => {
    let active = 0
    let pending = 0
    for (const access of accessList) {
      if (isAccessActive(access)) {
        active += 1
      } else if (isAccessPending(access)) {
        pending += 1
      }
    }
    return { active, pending }
  }, [accessList])

  const knownEnvironments = ['production', 'staging', 'testing', 'development']
  const availableEnvironments = useMemo(() => {
    const found = new Set<string>()
    for (const server of servers) {
      if (server.environment) {
        found.add(server.environment.toLowerCase())
      }
    }
    return knownEnvironments.filter((env) => found.has(env))
  }, [servers])

  const hasOtherEnvironment = useMemo(() => {
    return servers.some((server) => {
      if (!server.environment) return true
      return !knownEnvironments.includes(server.environment.toLowerCase())
    })
  }, [servers])

  const filteredServers = useMemo(() => {
    return servers.filter((server) => {
      if (environmentFilter !== 'all') {
        const env = server.environment?.toLowerCase()
        if (environmentFilter === 'other') {
          if (env && knownEnvironments.includes(env)) return false
        } else if (env !== environmentFilter) {
          return false
        }
      }

      if (normalizedSearch) {
        const haystack = [
          server.name,
          server.description ?? '',
          server.server_type ?? '',
          server.environment ?? '',
        ]
          .join(' ')
          .toLowerCase()
        if (!haystack.includes(normalizedSearch)) return false
      }

      return true
    })
  }, [servers, environmentFilter, normalizedSearch])

  const isLoading = accessLoading || serversLoading
  const error = accessError ?? serversError

  if (isLoading) {
    return <LoadingSpinner />
  }

  if (error) {
    return (
      <div className="p-8">
        <Heading>Home</Heading>
        <Text className="mt-2 text-sm text-red-600">Failed to load access: {error.message}</Text>
      </div>
    )
  }

  return (
    <div className="min-h-full">
      {/* Minimal Header */}
      <div className="px-6 py-8">
        <div className="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <Heading className="text-2xl">Database Access</Heading>
            <Text className="mt-1 text-zinc-500 dark:text-zinc-400">
              Connect to servers you have access to, or request access.
            </Text>
            <div className="mt-3 flex flex-wrap gap-2 text-sm">
              <Badge color="zinc">{servers.length} servers</Badge>
              <Badge color="emerald">{accessCounts.active} active access</Badge>
              <Badge color="amber">{accessCounts.pending} pending</Badge>
            </div>
          </div>
          <div className="w-full max-w-xl space-y-2">
            <div className="grid grid-cols-1 gap-2 sm:grid-cols-3">
              <InputGroup>
                <MagnifyingGlassIcon data-slot="icon" className="size-4" />
                <Input
                  type="search"
                  placeholder="Search servers or profiles..."
                  value={searchQuery}
                  onChange={(event) => setSearchQuery(event.target.value)}
                />
              </InputGroup>
              <Select
                value={accessFilter}
                onChange={(event) => setAccessFilter(event.target.value as AccessFilter)}
              >
                <option value="all">All access</option>
                <option value="active">Active access</option>
                <option value="pending">Pending requests</option>
                <option value="no-access">No access</option>
              </Select>
              <Select
                value={environmentFilter}
                onChange={(event) => setEnvironmentFilter(event.target.value as EnvironmentFilter)}
              >
                <option value="all">All environments</option>
                {availableEnvironments.map((environment) => (
                  <option key={environment} value={environment}>
                    {capitalize(environment)}
                  </option>
                ))}
                {hasOtherEnvironment && <option value="other">Other / Unset</option>}
              </Select>
            </div>
            {(searchQuery || accessFilter !== 'all' || environmentFilter !== 'all') && (
              <div className="flex items-center justify-between text-xs text-zinc-500 dark:text-zinc-400">
                <span>
                  Showing {filteredServers.length} of {servers.length} servers
                </span>
                <Button
                  plain
                  compact
                  onClick={() => {
                    setSearchQuery('')
                    setAccessFilter('all')
                    setEnvironmentFilter('all')
                  }}
                >
                  Clear filters
                </Button>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* Server List */}
      <div className="px-6 pb-10">
        {servers.length === 0 ? (
          <div className="rounded-lg border border-border bg-card p-8">
            <EmptyState
              icon={CircleStackIconOutline}
              title="No Servers Yet"
              message="No servers have been configured in this workspace. Contact your workspace admin to add database servers."
            />
          </div>
        ) : filteredServers.length === 0 ? (
          <div className="rounded-lg border border-border bg-card p-8">
            <EmptyState
              icon={FunnelIcon}
              title="No Matches"
              message="No servers match your current filters. Try adjusting your search or filters to see more results."
            />
          </div>
        ) : (
          <div className="space-y-1">
            {filteredServers.map((server) => (
              <ServerRow
                key={server.id}
                server={server}
                accessByProfile={accessByProfile}
                pendingByProfile={pendingByProfile}
                searchQuery={normalizedSearch}
                accessFilter={accessFilter}
              />
            ))}
          </div>
        )}
      </div>
    </div>
  )
}

// Database-specific icons as SVG components
