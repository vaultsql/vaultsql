    </svg>
  )
}

function ServerIcon({ serverType, isActive }: { serverType: string; isActive: boolean }) {
  const activeClass = isActive
    ? 'text-emerald-600 dark:text-emerald-400'
    : 'text-zinc-400 dark:text-zinc-600'
  const iconClass = `mt-0.5 h-5 w-5 flex-shrink-0 ${activeClass}`

  switch (serverType.toLowerCase()) {
    case 'mysql':
      return <MySQLIcon className={iconClass} />
    case 'postgres':
    case 'postgresql':
      return <PostgreSQLIcon className={iconClass} />
    default:
      return <CircleStackIcon className={iconClass} />
  }
}

function ServerRow({
  server,
  accessByProfile,
  pendingByProfile,
  searchQuery,
  accessFilter,
}: {
  server: Server
  accessByProfile: Map<string, Access>
  pendingByProfile: Map<string, Access>
  searchQuery: string
  accessFilter: AccessFilter
}) {
  return (
    <Disclosure>
      {({ open }) => (
        <ServerRowContent
          server={server}
          accessByProfile={accessByProfile}
          pendingByProfile={pendingByProfile}
          searchQuery={searchQuery}
          accessFilter={accessFilter}
          open={open}
        />
      )}
    </Disclosure>
  )
}

function ServerRowContent({
  server,
  accessByProfile,
  pendingByProfile,
  searchQuery,
  accessFilter,
  open,
}: {
  server: Server
  accessByProfile: Map<string, Access>
  pendingByProfile: Map<string, Access>
  searchQuery: string
  accessFilter: AccessFilter
  open: boolean
}) {
  const { data: profiles = [], isLoading } = useServerProfiles(server.id, { enabled: open })

  if (!open && profiles.length === 0 && !isLoading) {
    return (
      <div
        className={`group rounded-lg border border-border bg-card py-4 transition hover:bg-zinc-50/50 dark:hover:bg-zinc-900/30 ${getEnvironmentBorder(server.environment)}`}
      >
        <Disclosure.Button className="flex w-full items-start justify-between gap-4 px-6 text-left">
          <ServerHeader server={server} />
          <div className="flex items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400">
            <span className="font-mono">{server.server_type}</span>
            <ChevronDownIcon
              className={`size-4 transition-transform ${open ? 'rotate-180' : ''}`}
            />
          </div>
        </Disclosure.Button>
        <div className="mt-2 px-6 text-xs text-zinc-500 dark:text-zinc-400">
          Expand to view profiles.
        </div>
      </div>
    )
  }

  const filteredProfiles = profiles.filter((profile) => {
    const hasAccess = Boolean(accessByProfile.get(profile.id))
    const hasPending = Boolean(pendingByProfile.get(profile.id))

    if (accessFilter !== 'all') {
      if (accessFilter === 'active' && !hasAccess) return false
      if (accessFilter === 'pending' && !hasPending) return false
      if (accessFilter === 'no-access' && (hasAccess || hasPending)) return false
    }

    if (searchQuery) {
      const profileHaystack = [profile.name, profile.description ?? ''].join(' ').toLowerCase()
      if (!profileHaystack.includes(searchQuery)) return false
    }

    return true
  })

  return (
    <div
      className={`group rounded-lg border border-border bg-card py-4 transition hover:bg-zinc-50/50 dark:hover:bg-zinc-900/30 ${getEnvironmentBorder(server.environment)}`}
    >
      {/* Server Header */}
      <div className="flex items-start justify-between gap-4 px-6">
        <Disclosure.Button className="flex w-full items-start justify-between gap-4 text-left">
          <ServerHeader server={server} />
          <div className="flex items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400">
            <span className="font-mono">{server.server_type}</span>
            <ChevronDownIcon
              className={`size-4 transition-transform ${open ? 'rotate-180' : ''}`}
            />
          </div>
        </Disclosure.Button>
      </div>

      {/* Profile List */}
      {open && (
        <>
          {isLoading ? (
            <div className="mt-3 px-6 text-sm text-zinc-500">Loading profiles...</div>
          ) : profiles.length === 0 ? (
            <div className="mt-3 px-6 text-sm text-zinc-500">
              No profiles configured for this server.
            </div>
          ) : filteredProfiles.length === 0 ? (
            <div className="mt-3 px-6 text-sm text-zinc-500">
              No profiles match your filters.
            </div>
          ) : (
            <div className="mt-3 space-y-0.5">
              {filteredProfiles.map((profile) => (
                <ProfileRow
                  key={profile.id}
                  profile={profile}
                  server={server}
                  access={accessByProfile.get(profile.id)}
                  pendingAccess={pendingByProfile.get(profile.id)}
                />
              ))}
            </div>
          )}
        </>
      )}
    </div>
  )
}

function ProfileRow({
  profile,
  server,
  access,
  pendingAccess,
}: {
  profile: Profile
  server: Server
  access?: Access
  pendingAccess?: Access
}) {
  const [showRequestDialog, setShowRequestDialog] = useState(false)
  const hasAccess = Boolean(access)
  const hasPendingRequest = Boolean(pendingAccess)
  const isServerActive = server.is_active

  // Get access level icon
  const AccessLevelIcon = () => {
    const iconClass = 'h-4 w-4 flex-shrink-0'
    switch (profile.access_level?.toLowerCase()) {
      case 'readonly':
        return <LockOpenIcon className={iconClass} />
      case 'write':
        return <PencilIcon className={iconClass} />
      case 'admin':
        return <ShieldCheckIcon className={iconClass} />
      default:
        return <LockOpenIcon className={iconClass} />
    }
  }

  const status = hasAccess ? 'active' : hasPendingRequest ? 'pending' : 'none'
  const statusBadge = status === 'active' ? (
    <Badge color="green" className="text-xs">
      Active
    </Badge>
  ) : status === 'pending' ? (
    <Badge color="amber" className="text-xs">
      Pending
    </Badge>
  ) : (
    <Badge color="zinc" className="text-xs">
      No access
    </Badge>
  )
  const accessExpiryLabel = access?.granted_until
    ? `Until ${formatAccessExpiry(access.granted_until)}`
    : null

  return (
    <>
      <div className="group/row flex items-center justify-between gap-4 px-6 py-2.5 pl-12 hover:bg-zinc-100/80 dark:hover:bg-zinc-800/50">
        {/* Left: Icon + Profile Info */}
        <div className="flex min-w-0 flex-1 items-center gap-3">
          <div
            className={
              hasPendingRequest
                ? 'text-amber-700 dark:text-amber-400'
                : hasAccess
                  ? 'text-zinc-900 dark:text-zinc-100'
                  : 'text-zinc-400 dark:text-zinc-500'
            }
          >
            <AccessLevelIcon />
          </div>
          <div className="min-w-0 flex-1">
            <div className="flex items-baseline gap-3">
              <span
                className={`text-sm font-medium ${
                  hasPendingRequest
                    ? 'text-amber-700 dark:text-amber-400'
                    : hasAccess
                      ? 'text-zinc-900 dark:text-zinc-100'
                      : 'text-zinc-400 dark:text-zinc-500'
                }`}
              >
                {profile.name}
              </span>
              <Badge color={getAccessLevelBadgeColor(profile.access_level)} className="text-xs">
                {getAccessLevelLabel(profile.access_level)}
              </Badge>
              {statusBadge}
            </div>
            {accessExpiryLabel && (
              <span className="text-xs text-zinc-500 dark:text-zinc-400">
                {accessExpiryLabel}
              </span>
            )}
            {profile.description && (
              <p className="mt-0.5 truncate text-xs text-zinc-500 dark:text-zinc-400">
                {profile.description}
              </p>
            )}
          </div>
        </div>

        {/* Right: Action Button */}
        <div className="flex-shrink-0">
          {!isServerActive ? (
            <Button disabled outline>
              Inactive
            </Button>
          ) : hasAccess ? (
            <Button href={`/workbench/${profile.id}`}>Connect</Button>
          ) : hasPendingRequest ? (
            <Button disabled outline className="text-amber-700 dark:text-amber-400">
              <ClockIcon className="-ml-1 mr-1.5 h-4 w-4" />
              Pending
            </Button>
          ) : (
            <Button outline onClick={() => setShowRequestDialog(true)}>
              <LockClosedIcon className="-ml-1 mr-1.5 h-4 w-4" />
              Request
            </Button>
          )}
        </div>
      </div>

      <RequestAccessDialog
        open={showRequestDialog}
        onClose={() => setShowRequestDialog(false)}
        serverId={server.id}
        profileId={profile.id}
        profileName={profile.name}
        serverName={server.name}
      />
    </>
  )
}

function ServerHeader({ server }: { server: Server }) {
  return (
    <div className="flex items-start gap-3">
      <ServerIcon serverType={server.server_type} isActive={server.is_active} />
      <div>
        <div className="flex flex-wrap items-center gap-2">
          <h3 className="text-base font-semibold text-zinc-900 dark:text-zinc-100">
            {server.name}
          </h3>
          {server.environment && (
            <Badge color={getEnvironmentBadgeColor(server.environment)} className="text-xs uppercase">
              {getEnvironmentLabel(server.environment)}
            </Badge>
          )}
          {!server.is_active && (
            <Badge color="zinc" className="text-xs">
              Inactive
            </Badge>
          )}
        </div>
        {server.description && (
          <p className="mt-0.5 text-sm text-zinc-600 dark:text-zinc-400">{server.description}</p>
        )}
      </div>
    </div>
  )
}

function getEnvironmentBorder(environment?: string | null) {
  if (!environment) return ''
  switch (environment.toLowerCase()) {
    case 'production':
      return 'border-l-4 border-l-red-500'
    case 'staging':
      return 'border-l-4 border-l-blue-400'
    default:
      return ''
  }
}

function formatAccessExpiry(grantedUntil?: string | null) {
  if (!grantedUntil) return ''
  return new Date(grantedUntil).toLocaleDateString(undefined, {
    month: 'short',
    day: 'numeric',
  })
}

function capitalize(value: string) {
  return value.charAt(0).toUpperCase() + value.slice(1)
}

