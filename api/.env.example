# api Environment Variables
#
# Secrets are managed in Doppler (project: api)
# .env files are gitignored - this file serves as a reference
#
# Local dev: doppler run -- <command>
# Or use: ./dev.sh from repo root
#
# Auto-generated by sync-env-example.sh

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
DB_HOST=localhost
DB_NAME=mydb
DB_PASS=your-db_pass-here
DB_PORT=5432
DB_SSLMODE=disable
DB_USER=postgres
FROM_EMAIL=support@vaultsql.com
FROM_NAME=VaultSQL
FRONTEND_URL=http://localhost:5173
DEV_LOGIN_EMAIL=dev@vaultsql.com
POSTMARK_API_KEY=your-postmark_api_key-here
QUERY_SERVICE_SECRET=your-query_service_secret-here
QUERY_SERVICE_URL=http://localhost:9005
SECRET_KEY=your-secret_key-here
SEND_EMAIL_FLAG=false
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
...
-----END OPENSSH PRIVATE KEY-----"
SSH_PUBLIC_KEY=your-ssh_public_key-here

# Optional object storage (S3-compatible, including Cloudflare R2)
ENABLE_R2=false
ENABLE_S3=false
API_R2_ACCESS_KEY=
API_R2_SECRET=
API_R2_ENDPOINT=
API_R2_BUCKET=
API_R2_DOMAIN=

# Optional image processing tuning
IMAGE_MAX_DIMENSION=512
IMAGE_WEBP_QUALITY=85
