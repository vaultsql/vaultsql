FROM golang:1.25.5-alpine

# Install git and air for hot-reload
RUN apk add --no-cache git && \
    go install github.com/air-verse/air@latest

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Expose port
EXPOSE 9005

# Run with air for hot-reload
CMD ["air", "-c", ".air.toml"]
